<!DOCTYPE html>
<html lang="et">
<head>
  <style>
    .social-media {
      padding: 40px 20px;
      background: #121212;
      color: #fff;
      text-align: center;
      font-family: sans-serif;
    }

    .social-media h2 {
      font-size: 2em;
      margin-bottom: 30px;
      font-weight: 700;
    }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
    }

    .icon-link {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: #fff;
      background: #222;
      padding: 20px;
      border-radius: 15px;
      width: 180px;
      height: 180px;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 0 10px rgba(255,255,255,0.1);
      box-sizing: border-box;
    }

    .icon-link:hover {
      transform: scale(1.1);
      box-shadow: 0 0 25px #ff0000;
    }

    .icon-link img {
      width: 80px;
      height: 80px;
      margin-bottom: 15px;
      border-radius: 50%;
      background: #000;
      padding: 10px;
      object-fit: cover;
    }

    .icon-link span {
      font-weight: 600;
      font-size: 0.9em;
    }
  </style>
</head>
<body>

  <section class="social-media">
    <h2>Join my channels</h2>
    <div class="social-links">
      
      <a href="/go/youtube/" target="_blank" class="icon-link" aria-label="YouTube channel Dog Expert Tech">
        <img src="/assets/expertyoutube.jpg" alt="YouTube" />
        <span>Dog Expert</span>
      </a>

      <a href="/go/youtubeextra/" target="_blank" class="icon-link" aria-label="YouTube channel Dog Expert Extra">
        <img src="/assets/expertextrayoutube.jpg" alt="YouTube" />
        <span>Dog Expert Extra</span>
      </a>

      <a href="/go/discord/" target="_blank" class="icon-link" aria-label="Discord server Dog Expert Tech">
        <img src="/assets/discord.png" alt="Discord" />
        <span>Discord Server</span>
      </a>

    </div>
  </section>

</body>
</html>