---
import Layout from '../layouts/Layout.astro';
import {
  operatingSystemDownloads,
  isoImageDownloads,
} from '../data/iso-downloads';
---

<Layout
  title="ISOs & Operating Systems"
  description="Download Windows ISOs, WinPE images, and operating system installers."
>
  <section class="hero">
    <h1>ISOs & Operating Systems</h1>
    <p>
      Windows installers, recovery images, and custom PE environments. For ZIP archives and tools,
      visit the <a href="/files/">files library</a>.
    </p>
  </section>

  <section class="iso-section">
    <h2>Operating Systems</h2>
    <p class="section-intro">Official download pages and mirrored Windows / WinPE images.</p>
    <div class="iso-grid">
      {
        operatingSystemDownloads.map((item) => (
          <article class="iso-card">
            <span class="iso-badge">{item.badge}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a
              class="iso-btn"
              href={item.href}
              target={item.external || item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.external || item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              Download
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="iso-section">
    <h2>ISO Images</h2>
    <p class="section-intro">Disk images hosted in the file library.</p>
    <div class="iso-grid">
      {
        isoImageDownloads.map((item) => (
          <article class="iso-card">
            <span class="iso-badge">{item.badge}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a
              class="iso-btn"
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              Download
            </a>
          </article>
        ))
      }
    </div>

    <div class="table-container">
      <table class="iso-files-table">
        <thead>
          <tr>
            <th>File Name</th>
            <th>Size</th>
            <th class="text-right">Action</th>
          </tr>
        </thead>
        <tbody id="isoFilesBody">
          <tr>
            <td colspan="3" class="empty">Loading ISO files…</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 2em 1em 1.5em;
  }

  .hero h1 {
    font-size: 2.5em;
    margin-bottom: 0.5em;
    color: #005f73;
  }

  body.dark .hero h1 {
    color: #94d2bd;
  }

  .hero p {
    max-width: 640px;
    margin: 0 auto;
    color: #555;
    line-height: 1.6;
  }

  body.dark .hero p {
    color: #aaa;
  }

  .hero a {
    color: #005f73;
    font-weight: 600;
  }

  body.dark .hero a {
    color: #94d2bd;
  }

  .iso-section {
    margin-bottom: 3.5em;
  }

  .iso-section h2 {
    font-size: 2rem;
    text-align: center;
    margin-bottom: 0.5em;
    color: #005f73;
  }

  body.dark .iso-section h2 {
    color: #94d2bd;
  }

  .section-intro {
    text-align: center;
    color: #666;
    margin-bottom: 1.5em;
  }

  body.dark .section-intro {
    color: #aaa;
  }

  .iso-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 2em;
  }

  .iso-card {
    background: #fff;
    border-radius: 18px;
    padding: 24px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 200px;
  }

  body.dark .iso-card {
    background: #1d1d1d;
    color: #ddd;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  }

  .iso-badge {
    display: inline-block;
    color: #fff;
    background: #005f73;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    width: fit-content;
  }

  .iso-card h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  body.dark .iso-card h3 {
    color: #fff;
  }

  .iso-card p {
    flex-grow: 1;
    color: #555;
    font-size: 0.95rem;
  }

  body.dark .iso-card p {
    color: #bbb;
  }

  .iso-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #005f73;
    color: white;
    text-decoration: none;
    padding: 12px 18px;
    border-radius: 10px;
    font-weight: 700;
    transition: background 0.2s, transform 0.2s;
  }

  .iso-btn:hover {
    background: #094d56;
    transform: translateY(-2px);
  }

  .table-container {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid #e0e0e0;
    background: #fafafa;
  }

  body.dark .table-container {
    border-color: #333;
    background: #141414;
  }

  .iso-files-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 500px;
  }

  .iso-files-table th {
    padding: 16px 20px;
    text-align: left;
    color: #005f73;
    background: #f0f4f4;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  body.dark .iso-files-table th {
    color: #94d2bd;
    background: #1a1a1a;
  }

  .iso-files-table td {
    padding: 16px 20px;
    border-top: 1px solid #e8e8e8;
    vertical-align: middle;
  }

  body.dark .iso-files-table td {
    border-color: #2a2a2a;
    color: #ddd;
  }

  .text-right {
    text-align: right;
  }

  .empty {
    text-align: center;
    color: #888;
    padding: 2rem !important;
  }

  .file-title {
    font-weight: 600;
  }

  .file-size {
    font-family: monospace;
    color: #888;
  }

  .download-link {
    display: inline-flex;
    padding: 10px 18px;
    background: #1a56db;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .download-link:hover {
    background: #2563eb;
  }
</style>

<style is:global>
  .iso-files-table .download-link {
    display: inline-flex;
    padding: 10px 18px;
    background: #1a56db;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .iso-files-table .download-link:hover {
    background: #2563eb;
  }
</style>

<script>
  function getExtension(name) {
    const match = name.match(/\.([a-z0-9]+)$/i);
    return match ? match[1].toUpperCase() : '';
  }

  function isIsoFile(file) {
    const ext = getExtension(file.name);
    const mime = (file.mimeType || '').toLowerCase();
    return ext === 'ISO' || mime.includes('iso9660');
  }

  function formatBytes(bytes) {
    const value = Number(bytes);
    if (Number.isNaN(value)) return 'N/A';
    const units = ['B', 'KB', 'MB', 'GB', 'TB'];
    let index = 0;
    let size = value;
    while (size >= 1024 && index < units.length - 1) {
      size /= 1024;
      index++;
    }
    return `${size.toFixed(1)} ${units[index]}`;
  }

  function escapeHtml(text) {
    const el = document.createElement('span');
    el.textContent = text;
    return el.innerHTML;
  }

  function loadIsoFiles() {
    const tbody = document.getElementById('isoFilesBody');
    if (!tbody) return;

    fetch('/assets/files.json')
      .then((r) => r.json())
      .then((data) => {
        const isos = (data.files || []).filter(isIsoFile);

        if (!isos.length) {
          tbody.innerHTML =
            '<tr><td colspan="3" class="empty">No ISO files in the library yet.</td></tr>';
          return;
        }

        tbody.innerHTML = '';
        isos.forEach((file) => {
          const row = document.createElement('tr');
          row.innerHTML = `
            <td><span class="file-title">${escapeHtml(file.name)}</span></td>
            <td class="file-size">${formatBytes(file.size)}</td>
            <td class="text-right">
              <a class="download-link" href="${escapeHtml(file.webContentLink)}" target="_blank" rel="noopener noreferrer">Download</a>
            </td>
          `;
          tbody.appendChild(row);
        });
      })
      .catch(() => {
        tbody.innerHTML =
          '<tr><td colspan="3" class="empty">Could not load ISO files.</td></tr>';
      });
  }

  loadIsoFiles();
  document.addEventListener('astro:page-load', loadIsoFiles);
</script>
