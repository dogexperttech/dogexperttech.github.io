---
import Layout from '../layouts/Layout.astro';

const devices = [
  {
    name: 'Main PC',
    role: 'Primary workstation',
    image: '/about/assets/mainpc.png',
    specs: [
      'CPU: AMD Ryzen 7 5800X',
      'GPU: NVIDIA GeForce RTX 3070',
      'RAM: 32 GB DDR4',
      'Storage: 1 TB NVMe SSD',
      'OS: Windows 11 Pro',
    ],
  },
  {
    name: 'Full Desk Setup',
    role: 'Streaming & editing',
    image: '/about/assets/full setup.jpeg',
    specs: [
      'Dual-monitor workspace',
      'Custom cooling & cable management',
      'Used for YouTube and live content',
    ],
  },
  {
    name: 'HP ProBook Laptop',
    role: 'Portable daily driver',
    image: '/about/assets/laptop2.jpg',
    specs: [
      'Business-class HP ProBook',
      'Windows 11',
      'Used for travel and school/work tasks',
    ],
  },
  {
    name: 'MSI Laptop',
    role: 'Secondary laptop',
    image: '/about/assets/laptop3.jpg',
    specs: [
      'MSI gaming / creator chassis',
      'Testing software and older Windows builds',
    ],
  },
  {
    name: 'Raspberry Pi 5',
    role: 'SBC projects',
    image: '/about/assets/rpi5.jpg',
    specs: [
      'Raspberry Pi 5 board',
      'Raspberry Pi OS / Linux',
      'IoT, experiments, and lightweight dev',
    ],
  },
  {
    name: 'Raspberry Pi Project',
    role: 'Homelab & GPIO',
    image: '/about/assets/rpir.jpeg',
    specs: [
      'Custom Pi enclosure and wiring',
      'Network services and automation tests',
    ],
  },
  {
    name: 'iPad 4',
    role: 'Tablet',
    image: '/about/assets/ipad 4.jpg',
    specs: [
      'Apple iPad 4',
      'Media, notes, and light browsing',
    ],
  },
  {
    name: 'Samsung A56 5G',
    role: 'Main phone',
    image: '/about/assets/mainphone.jpg',
    specs: [
      'Samsung Galaxy A56 5G',
      'Android — daily communication & social',
    ],
  },
];

const software = [
  { name: 'Windows 11 Pro', link: 'https://www.microsoft.com/en-us/software-download/windows11' },
  { name: 'Visual Studio Code', link: 'https://code.visualstudio.com/' },
  { name: 'Paint.NET', link: 'https://www.getpaint.net/' },
  { name: 'OBS Studio', link: 'https://obsproject.com/' },
  { name: 'Discord', link: 'https://discord.com/' },
  { name: 'Google Chrome', link: 'https://www.google.com/chrome/' },
  { name: 'Git & GitHub', link: 'https://github.com/' },
  { name: 'PowerShell', link: 'https://github.com/PowerShell/PowerShell' },
  { name: 'Node.js', link: 'https://nodejs.org/' },
];
---

<Layout title="About" description="About Dog Expert Tech — devices, specs, and projects.">
  <section class="hero">
    <h1>About Me</h1>
    <p>This is my personal website where I share my projects, files, and thoughts.</p>
  </section>

  <section class="about-content">
    <h2>What I do</h2>
    <ul class="about-list">
      <li>I create games</li>
      <li>I develop software</li>
      <li>I make videos</li>
    </ul>

    <h2>My Devices</h2>
    <p class="section-note">
      Hardware I use for development, content creation, and experiments.
    </p>
    <div class="devices-grid">
      {
        devices.map((device) => (
          <article class="device-card">
            <a
              href={device.image}
              class="device-thumb"
              data-src={device.image}
              data-title={device.name}
            >
              <img
                src={device.image}
                alt={device.name}
                loading="lazy"
                onerror="this.closest('.device-thumb')?.classList.add('no-image')"
              />
              <span class="device-thumb-label">{device.name}</span>
            </a>
            <div class="device-body">
              <h3>{device.name}</h3>
              <p class="device-role">{device.role}</p>
              <ul>
                {device.specs.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <section class="software-section">
      <h2>Software I Use</h2>
      <p class="section-note">Core apps and tools used across my devices.</p>
      <div class="software-list">
        {software.map((app) => (
          <a href={app.link} target="_blank" rel="noopener noreferrer" class="software-item">
            {app.name} <span class="software-arrow">↗</span>
          </a>
        ))}
      </div>
    </section>

    <section class="screenshot-section">
      <h2>Device + Screen Preview</h2>
      <p class="section-note">One picture shows the device, the other shows a current screen capture.</p>
      <div class="preview-grid">
        <article class="snapshot-card">
          <img src="/about/assets/mainpc.png" alt="Main PC device" loading="lazy" />
          <p>Main Device</p>
        </article>
        <article class="snapshot-card">
          <img src="/about/assets/viwes.png" alt="Device screen screenshot" loading="lazy" />
          <p>Screen Screenshot</p>
        </article>
      </div>
    </section>

    <h2>Device Gallery</h2>
    <p class="section-note">Click any photo to view full size.</p>
    <div id="lightgallery" class="gallery">
      {
        devices.map((device) => (
          <a
            href={device.image}
            data-src={device.image}
            data-title={device.name}
            class="gallery-link"
          >
            <img src={device.image} alt={device.name} loading="lazy" />
            <span>{device.name}</span>
          </a>
        ))
      }
    </div>
  </section>

  <div id="about-lightbox" class="about-lightbox" hidden aria-hidden="true">
    <button type="button" class="about-lightbox-close" aria-label="Close">✕</button>
    <img id="about-lightbox-img" src="" alt="" />
    <p id="about-lightbox-caption"></p>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const lightbox = document.getElementById('about-lightbox');
    const lightboxImg = document.getElementById('about-lightbox-img');
    const caption = document.getElementById('about-lightbox-caption');
    const closeButton = document.querySelector('.about-lightbox-close');

    function openLightbox(src, title) {
      lightboxImg.src = src;
      caption.textContent = title || '';
      lightbox.hidden = false;
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.classList.add('lightbox-open');
    }

    function closeLightbox() {
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('lightbox-open');
    }

    document.querySelectorAll('.device-thumb, .gallery-link, .snapshot-card img').forEach((item) => {
      item.addEventListener('click', function (event) {
        event.preventDefault();
        const target = event.currentTarget;
        const src = target.getAttribute('href') || target.getAttribute('src') || target.dataset.src;
        const title = target.dataset.title || target.alt || target.querySelector('img')?.alt || '';
        if (src) {
          openLightbox(src, title);
        }
      });
    });

    closeButton.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', function (event) {
      if (event.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeLightbox();
    });
  });
</script>

<style>
  .about-content {
    padding: 20px 0 40px;
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    color: var(--site-heading);
    margin-top: 2em;
    margin-bottom: 0.75em;
    font-size: 1.8em;
  }

  .section-note {
    color: var(--site-muted);
    margin-bottom: 1.25em;
  }

  .about-list {
    list-style: none;
    padding-left: 0;
  }

  .about-list li {
    padding: 10px 0 10px 25px;
    position: relative;
    font-size: 1.1em;
  }

  .about-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #ff0000;
    font-weight: bold;
  }

  .devices-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 2em;
  }

  .device-card {
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transition: transform 0.25s, box-shadow 0.25s;
  }

  html[data-theme='dark'] .device-card {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }

  .device-card:hover {
    transform: translateY(-4px);
  }

  .device-thumb {
    display: block;
    position: relative;
    background: #e8e8e8;
    min-height: 160px;
    text-decoration: none;
    cursor: pointer;
  }

  html[data-theme='dark'] .device-thumb {
    background: #2a2a2a;
  }

  .device-thumb.no-image {
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .device-thumb.no-image img {
    display: none;
  }

  .device-thumb img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .device-thumb-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 8px 12px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.75));
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .device-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .device-body h3 {
    margin: 0 0 0.25em;
    color: var(--site-heading);
    font-size: 1.15rem;
  }

  .device-role {
    color: var(--site-muted);
    font-size: 0.9rem;
    margin-bottom: 0.75em;
  }

  .device-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .device-body ul li {
    padding: 4px 0;
    font-size: 0.92rem;
    color: var(--site-text);
    border-bottom: 1px solid var(--site-border);
  }

  .device-body ul li:last-child {
    border-bottom: none;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 14px;
    margin-bottom: 40px;
  }

  .gallery-link {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 10px;
    border: 2px solid var(--site-border);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.3s, transform 0.3s;
    background: var(--site-card);
  }

  .gallery-link:hover {
    border-color: #ff0000;
    transform: scale(1.02);
  }

  .gallery-link img {
    width: 100%;
    height: 130px;
    object-fit: cover;
    display: block;
  }

  .gallery-link span {
    padding: 8px 10px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--site-text);
    text-align: center;
  }

  .software-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin: 1rem 0 2rem;
  }

  .software-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: 14px;
    padding: 16px;
    font-weight: 600;
    color: var(--site-text);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .software-item:hover {
    transform: translateY(-3px);
    border-color: #ff0000;
    box-shadow: 0 8px 24px rgba(255, 0, 0, 0.15);
  }

  .software-arrow {
    color: #ff0000;
    font-size: 1.1em;
    transition: transform 0.2s;
  }

  .software-item:hover .software-arrow {
    transform: translateX(3px);
  }

  .screenshot-section {
    margin-bottom: 2rem;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
    margin-bottom: 2.5rem;
  }

  .snapshot-card {
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    text-align: center;
    padding-bottom: 14px;
  }

  .snapshot-card img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  .snapshot-card p {
    margin: 12px 0 0;
    color: var(--site-text);
    font-weight: 700;
  }

  .about-lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 10000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
  }

  .about-lightbox[hidden] {
    display: none !important;
  }

  .about-lightbox img {
    max-width: min(92vw, 1100px);
    max-height: 75vh;
    border-radius: 8px;
    object-fit: contain;
  }

  .about-lightbox-caption {
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .about-lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .devices-grid {
      grid-template-columns: 1fr;
    }

    .gallery {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    }
  }
</style>

<script>
  function setupAboutGallery() {
    const lightbox = document.getElementById('about-lightbox');
    const lightboxImg = document.getElementById('about-lightbox-img');
    const caption = document.getElementById('about-lightbox-caption');
    const closeBtn = document.querySelector('.about-lightbox-close');

    function open(src, title) {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = src;
      lightboxImg.alt = title;
      if (caption) caption.textContent = title;
      lightbox.hidden = false;
      lightbox.setAttribute('aria-hidden', 'false');
    }

    function close() {
      if (!lightbox) return;
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
    }

    document.querySelectorAll('.gallery-link, .device-thumb').forEach((link) => {
      if (link.dataset.bound === 'true') return;
      link.dataset.bound = 'true';
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const src = link.getAttribute('data-src') || link.getAttribute('href');
        const title = link.getAttribute('data-title') || link.querySelector('span')?.textContent || 'Device';
        if (src) open(src, title);
      });
    });

    closeBtn?.addEventListener('click', close);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }

  setupAboutGallery();
  document.addEventListener('astro:page-load', setupAboutGallery);
</script>
